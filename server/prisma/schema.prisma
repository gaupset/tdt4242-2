generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AiCategory {
  BRAINSTORMING
  WRITING_ASSISTANCE
  RESEARCH
  CODE_GENERATION
  DEBUGGING
  DATA_ANALYSIS
  TRANSLATION
  SUMMARIZATION
  OTHER
}

enum AiExtent {
  MINIMAL
  MODERATE
  EXTENSIVE
}

enum DeclarationStatus {
  DRAFT
  SUBMITTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects     Project[]
  declarations Declaration[]

  @@map("users")
}

model Project {
  id             String   @id @default(uuid())
  name           String
  description    String?
  courseName     String
  assignmentName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiUsageLogs  AiUsageLog[]
  declarations Declaration[]

  @@map("projects")
}

model AiUsageLog {
  id        String     @id @default(uuid())
  toolName  String
  timestamp DateTime   @default(now())
  category  AiCategory
  extent    AiExtent
  purpose   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reflectionNote ReflectionNote?

  @@map("ai_usage_logs")
}

model ReflectionNote {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiUsageLogId String     @unique
  aiUsageLog   AiUsageLog @relation(fields: [aiUsageLogId], references: [id], onDelete: Cascade)

  @@map("reflection_notes")
}

model Declaration {
  id          String            @id @default(uuid())
  title       String
  summary     String
  status      DeclarationStatus @default(DRAFT)
  submittedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("declarations")
}
